// J-Link flash script for M1 Hapax firmware
// Load the firmware artifact produced by the build system.
// This script must reference a concrete binary path so J-Link can open it directly.
// Expected binary path: ./out/build/gcc-14_2_build-release/M1_Hapax.bin
si SWD
speed auto
device STM32H573VI
connect
erase
loadbin ./out/build/gcc-14_2_build-release/M1_Hapax.bin, 0x08000000
r
g
exit